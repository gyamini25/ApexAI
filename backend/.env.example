# ── IBM watsonx Granite credentials ─────────────────────────────────────────
# Get these from https://dataplatform.cloud.ibm.com → watsonx.ai project.
# Leave blank to run in SIM MODE (deterministic engineer engine — demo still works).
#
# NOTE: Granite *chat* models are region-specific. Frankfurt (eu-de) serves
# ibm/granite-4-h-small; Dallas (us-south) serves ibm/granite-3-8b-instruct.
# London (eu-gb) only has Granite embeddings — pick a region with a chat model.

WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_REGION=eu-de
WATSONX_MODEL_ID=ibm/granite-4-h-small

# Document extraction: set to 1 after `pip install docling` to use real Docling
# (otherwise PDFs fall back to pdf-parse — still works).
USE_DOCLING=0

PORT=8787
